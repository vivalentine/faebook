# FaeBook example environment file
#
# This file is documentation for humans and agents.
# The running app reads:
# - apps/server/.env
# - apps/client/.env.local
#
# Copy the relevant values into those files locally.
#
# Do not commit real secrets.

# =========================
# Server values
# =========================
PORT=3001
SESSION_SECRET=replace-with-a-long-random-secret
COOKIE_SECURE=0
TRUST_PROXY=0
CLIENT_URLS=http://localhost:5173,http://127.0.0.1:5173,http://vi-pc.local:5173,http://192.168.1.186:5173,http://localhost:3001,http://127.0.0.1:3001,http://vi-pc.local,http://192.168.1.186:3001

# =========================
# Client values
# =========================
VITE_API_BASE_URL=
VITE_DEV_HOSTNAME=vi-pc.local
VITE_DEV_PORT=5173
VITE_PREVIEW_PORT=4173