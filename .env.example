# FaeBook example environment file
#
# This file is documentation for humans and agents.
# The running app reads:
# - apps/server/.env
# - apps/client/.env.local
#
# Copy the relevant values into those files locally.
# Do not commit real secrets.

# =========================
# Server values (development)
# =========================
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
SESSION_SECRET=replace-with-a-long-random-secret
COOKIE_SECURE=0
TRUST_PROXY=0
CLIENT_URLS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3001,http://127.0.0.1:3001

# =========================
# Client values (development)
# =========================
VITE_API_BASE_URL=
VITE_DEV_HOSTNAME=localhost
VITE_DEV_PORT=5173
VITE_PREVIEW_PORT=4173
