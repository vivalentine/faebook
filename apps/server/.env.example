# Server runtime defaults (development-safe)
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
SESSION_SECRET=replace-with-a-long-random-secret
COOKIE_SECURE=0
TRUST_PROXY=0
CLIENT_URLS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3001,http://127.0.0.1:3001

# Optional hardening controls
JSON_BODY_LIMIT=1mb
MARKDOWN_UPLOAD_MAX_BYTES=2097152
IMAGE_UPLOAD_MAX_BYTES=10485760
MULTI_UPLOAD_MAX_FILES=50
LOGIN_RATE_LIMIT_WINDOW_MS=600000
LOGIN_RATE_LIMIT_MAX=20
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=180
HSTS_HEADER_VALUE=max-age=31536000; includeSubDomains
