# FaeBook production server env template
# Copy to apps/server/.env on the live host and replace placeholders.

NODE_ENV=production
PORT=3001
HOST=127.0.0.1
SESSION_SECRET=replace-with-a-very-long-random-secret
COOKIE_SECURE=1
TRUST_PROXY=true

# Public app hostname(s) that may issue browser requests.
# Keep this list tight and comma-separated.
CLIENT_URLS=https://faebook.example.com

# Optional hardening controls
JSON_BODY_LIMIT=1mb
MARKDOWN_UPLOAD_MAX_BYTES=2097152
IMAGE_UPLOAD_MAX_BYTES=10485760
MULTI_UPLOAD_MAX_FILES=50
LOGIN_RATE_LIMIT_WINDOW_MS=600000
LOGIN_RATE_LIMIT_MAX=20
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=180
HSTS_HEADER_VALUE=max-age=31536000; includeSubDomains
