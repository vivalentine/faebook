{$FAEBOOK_SITE_ADDRESS::80} {
	encode zstd gzip

	@api path /api/*
    handle @api {
	reverse_proxy 127.0.0.1:3001 {
		header_up X-Forwarded-Proto https
		header_up X-Forwarded-Host {host}
	}
    }

	@uploads path /uploads/*
	handle @uploads {
		root * {$FAEBOOK_ROOT:C:\Users\viole\Projects\faebook-repo\faebook}
		try_files {path} =404
		header Cache-Control "public, max-age=60"
		file_server
	}

	@assets path /assets/*
	handle @assets {
		root * {$FAEBOOK_CLIENT_DIST:C:\Users\viole\Projects\faebook-repo\faebook\apps\client\dist}
		try_files {path} =404
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	handle {
		root * {$FAEBOOK_CLIENT_DIST:C:\Users\viole\Projects\faebook-repo\faebook\apps\client\dist}
		@index path /index.html
		header @index Cache-Control "no-store"
		try_files {path} /index.html
		file_server
	}
}